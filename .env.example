# ============================================================================
# DEPLOYMENT MODE - UNCOMMENT THE SECTION YOU NEED
# ============================================================================
# Instructions:
# 1. Comment out all sections with #
# 2. Uncomment ONLY the section you need (LOCAL, INTRANET, or PRODUCTION)
# 3. Update URLs/IPs to match your setup
# ============================================================================

# ┌─────────────────────────────────────────────────────────────────────────┐
# │ LOCAL DEVELOPMENT (HTTP)                       │
# └─────────────────────────────────────────────────────────────────────────┘
APP_NAME=Laravel
APP_ENV=local
APP_DEBUG=true
APP_URL=http://react-template-api.test
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173
SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:3000
SANCTUM_TOKEN_EXPIRATION=10080
BCRYPT_ROUNDS=10
RATE_LIMIT_API=120
RATE_LIMIT_LOGIN=10
LOG_LEVEL=debug

# ┌─────────────────────────────────────────────────────────────────────────┐
# │ INTRANET DEPLOYMENT (HTTP) - Uncomment to use                        │
# └─────────────────────────────────────────────────────────────────────────┘
# APP_NAME=Laravel
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=http://app-api.domain.net
# CORS_ALLOWED_ORIGINS=http://app.domain.net
# SANCTUM_STATEFUL_DOMAINS=app.domain.net
# SANCTUM_TOKEN_EXPIRATION=10080
# BCRYPT_ROUNDS=10
# RATE_LIMIT_API=100
# RATE_LIMIT_LOGIN=8
# LOG_LEVEL=error

# ┌─────────────────────────────────────────────────────────────────────────┐
# │ PRODUCTION DEPLOYMENT (HTTPS) - Uncomment to use                     │
# └─────────────────────────────────────────────────────────────────────────┘
# APP_NAME=Laravel
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://app-api.domain.net
# CORS_ALLOWED_ORIGINS=https://app.domain.net
# SANCTUM_STATEFUL_DOMAINS=app.domain.net
# SANCTUM_TOKEN_EXPIRATION=1440
# BCRYPT_ROUNDS=12
# RATE_LIMIT_API=60
# RATE_LIMIT_LOGIN=5
# LOG_LEVEL=error


# ============================================================================
# SHARED SETTINGS - Don't change these unless needed
# ============================================================================
APP_KEY=base64:Gu/P697S+mZ9MUmzvQIG0BeC1cYRZH2NPp0DakLHOaw=
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file
PHP_CLI_SERVER_WORKERS=4


# ============================================================================
# DATABASE - Update credentials for each environment
# ============================================================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=reacttemplateapi
DB_USERNAME=root
DB_PASSWORD=089608946!aA

# For INTRANET/PRODUCTION - uncomment and update
# DB_HOST=db_server_ip
# DB_DATABASE=production_db
# DB_USERNAME=db_user
# DB_PASSWORD=secure_password


# ============================================================================
# MAIL SETTINGS
# ============================================================================
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# For PRODUCTION - uncomment and configure
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.mailtrap.io
# MAIL_PORT=2525
# MAIL_USERNAME=username
# MAIL_PASSWORD=password


# ============================================================================
# CACHE, QUEUE, SESSION
# ============================================================================
BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# SESSION (Not needed for API-only token auth)
# SESSION_DRIVER=database
# SESSION_LIFETIME=120


# ============================================================================
# Reverb
# app_key and app_secret is generated using <php -r "echo bin2hex(random_bytes(32));"> 
# generate new keys for production and intranet environments and update .env accordingly
# php artisan queue:work --sleep=0 in development for instant update
# ============================================================================
REVERB_APP_ID=react-template-api
REVERB_APP_KEY=7ef63893039be3dd08314b7bcb41675a40df1498cc271e3be2a52587d6178b8a
REVERB_APP_SECRET=9cb0c759e60f615481db42eeb2fed247d2f7571f033c9a645b6f3a69c1ff122b
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ============================================================================
# REDIS (Optional - Uncomment if using Redis)
# ============================================================================
# REDIS_CLIENT=phpredis
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379


# ============================================================================
# LOGGING
# ============================================================================
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null


# ============================================================================
# VITE (Frontend build tool)
# ============================================================================
VITE_APP_NAME="${APP_NAME}"


# ============================================================================
# QUICK REFERENCE
# ============================================================================
# To switch environments:
# 1. Comment out current active section (add # to each line)
# 2. Uncomment target section (remove # from each line)
# 3. Run: php artisan config:clear && php artisan optimize
# ============================================================================